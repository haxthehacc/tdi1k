DMACRO mos_dev type dev_name seed mos_g sd_lay mos_b aux mos_model{

#ifndef NO_DFM //{

LVS PROPERTY INITIALIZE type(dev_name) [
PROPERTY rf_flag
 in_rff = input_numeric_value ( rf_flag ) // get w if present in input
 if ( is_missing ( in_rff ) == 1 ) {
 rf_flag = 0 // replace a missing value with 0
 } else {
 rf_flag = in_rff // it is required to assign to all variables
 // declared in the leading PROPERTY statement
 }

]
#endif //}


#ifndef NO_DFM //{
DEVICE type(dev_name) seed mos_g(G) sd_lay(S) sd_lay(D) mos_b(B) <aux>  NETLIST MODEL mos_model
[

#ifdef RCX_run //{
 property W,L,AD,AS,PD,PS,postlayout
#endif  //}
#ifndef RCX_run //{
 property W,L
#endif  //}

 
 
#else //}{
DEVICE type(dev_name) seed mos_g(G) sd_lay(S) sd_lay(D) mos_b(B) <aux>  NETLIST MODEL mos_model
[

#ifdef RCX_run //{
 property W,L,AD,AS,PD,PS,postlayout
#endif  //}
#ifndef RCX_run //{
 property W,L
#endif  //}

#endif  //}

 L = (PERIMETER(seed) - PERIMETER_COINCIDE(seed,sd_lay)) / 2
 W = PERIMETER_COINCIDE(seed,sd_lay) / 2
 postlayout = "1"

 if (BENDS(seed) > 0) L= AREA(seed)/W
    // Calculate the SRC/DRN Perimeter/Area
#ifdef RCX_run //{
 PI_S_OD =  perimeter_inside(S, aux)
   if (PI_S_OD > 0) {
      AS = area(S) * W / PI_S_OD
      PS = perimeter(S) * W / PI_S_OD
   } else { AS = 0 PS = 0 }

   PI_D_OD =  perimeter_inside(D, aux)
   if (PI_D_OD > 0) {
      AD = area(D) * W / PI_D_OD
      PD = perimeter(D) * W / PI_D_OD
   } else { AD = 0 PD = 0 }
#endif  //}
]

TRACE PROPERTY type(dev_name) w w TOL_WL
TRACE PROPERTY type(dev_name) l l TOL_WL
#ifdef LVS_TECH ts18sl //{
#ifndef NO_DFM //{
TRACE PROPERTY type(dev_name) rf_flag rf_flag 0
#endif //}
#endif //}

LVS REDUCE type(dev_name) PARALLEL YES
// Reduce split gate devices in parallel.
[
#ifndef NO_DFM //{
	TOLERANCE rf_flag 0
#ifdef RCX_run //{
	effective W, L, AS, AD, PS, PD, rf_flag
#else
	effective W, L, rf_flag
#endif //}
// Calculate these effective values.
	ns = count()
	rf_flag = sum(rf_flag)/ns

#else //}{

#ifdef RCX_run //{
	effective W, L, AS, AD, PS, PD
#else
	effective W, L
#endif //}
// Calculate these effective values.
	ns = count()

#endif //}

P = sum( W * L ) // Sum of Wi * Li
Q = sum( W / L ) // Sum of Wi / Li
L = sqrt( P / Q ) // Effective L
W = sqrt( P * Q ) // Effective W
#ifdef RCX_run //{
	AS = sum( AS ) // Effective AS: sum of ASi
	AD = sum( AD ) // Effective AD: sum of ADi
	PS = sum( PS ) // Effective PS: sum of PSi
	PD = sum( PD ) // Effective PD: sum of PDi
#endif  //}
]


}

DMACRO mos_prop seed sd_lay aux {
[

#ifdef RCX_run //{
 property W,L,AD,AS,PD,PS
#endif  //}
#ifndef RCX_run //{
 property W,L
#endif  //}

 L = (PERIMETER(seed) - PERIMETER_COINCIDE(seed,sd_lay)) / 2
 W = PERIMETER_COINCIDE(seed,sd_lay) / 2
 IF (BENDS(seed) > 0) L= AREA(seed)/W
    // Calculate the SRC/DRN Perimeter/Area
#ifdef RCX_run //{
 PI_S_OD =  perimeter_inside(S, aux)
   IF (PI_S_OD > 0) {
      AS = area(S) * W / PI_S_OD
      PS = perimeter(S) * W / PI_S_OD
   } ELSE { AS = 0 PS = 0 }

   PI_D_OD =  perimeter_inside(D, aux)
   IF (PI_D_OD > 0) {
      AD = area(D) * W / PI_D_OD
      PD = perimeter(D) * W / PI_D_OD
   } ELSE { AD = 0 PD = 0 }
#endif  //}
]

}


DMACRO res_prop seed_layer port_ sheet_res delta_W  cres cs_pitch {
 [

#ifdef extract_r //{
  property L,W,R
#else
  property L,W
#endif  //}

  W = PERIMETER_COINCIDE(seed_layer,port_)/2
  L = AREA(seed_layer)/W
  rcon= (cres*cs_pitch)/W
#ifdef extract_r //{
   R = (2*rcon) + (sheet_res * L)/(W - delta_W)
// R = sheet_res*(L/W)
#endif   //}
 ]
}

DMACRO m_res_prop seed_layer port_ sheet_res{
 [

#ifdef extract_r //{
  property L,W,R
#else
  property L,W
#endif  //}

  W = PERIMETER_COINCIDE(seed_layer,port_)/2
  L = AREA(seed_layer)/W
#ifdef extract_r //{
   R = sheet_res*(L/W)
#endif   //}
 ]
}//=====================================================

DMACRO res_prop_rint seed_layer port_ sheet_res delta_W  cres cs_pitch  rint {
 [

#ifdef extract_r //{
  #ifdef res_segs_on
    property L,W,R,NS,LS	//#ifdef extract_r + res_segs_on
    NS = 1
  #else
    property L,W,R	//#ifdef extract_r
  #endif
#else
  property L,W	//nothing defined
#endif  //}

  W = PERIMETER_COINCIDE(seed_layer,port_)/2
  L = AREA(seed_layer)/W
  rcon= (cres*cs_pitch)/W
  rend = rint/(W-delta_W)
#ifdef extract_r //{
  R = (2*rcon) + (2*rend) + (sheet_res * L)/(W - delta_W)
#endif   //}
#ifdef res_segs_on
  LS = L
#endif
 ]
}


