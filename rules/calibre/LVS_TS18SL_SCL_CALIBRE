// MIM_sq property macro
//---------------------------------------------------------

DMACRO mim_prop  seed_layer area_c fringe_c bias{
[

#ifdef RCX_run //{
       	PROPERTY L,W
#else //}{
	#ifdef ANALOG //{
        	PROPERTY L,W,C
	#else //}{
        	PROPERTY C
	#endif//}
#endif//}
	        A = area(seed_layer)
	        P = perimeter(seed_layer)

	if ((16*A-P*P) > 0)
	{        W = P/4
	         L = P/4
	}
	else
	{       W = (P-sqrt(P*P-16*A))/4
	        L = (P+sqrt(P*P-16*A))/4
	}

		C=area_c*(L-bias)*(W-bias)+fringe_c*2*(L-bias+W-bias)
]
}


