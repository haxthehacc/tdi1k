// LVS OPTIONS

#ifndef PORT_NAMES NO//{
LVS CHECK PORT NAMES YES
#endif//}

LVS IGNORE PORTS YES

LVS REPORT MAXIMUM 2000
LVS REPORT OPTION S

LVS RECOGNIZE GATES ALL


VIRTUAL CONNECT COLON YES
TEXT DEPTH PRIMARY

//  ******************************************************************************************************************
//  **********   NOTE:  TO CANCEL FILTERING OF UNUSED DEVICES PLEASE COMMENT OUT THE LINE BELOW!       ***************
//  ******************************************************************************************************************

LVS FILTER UNUSED OPTION AB RC RE RG

//    **************************************************************************************************************

LVS POWER NAME VDD vdd VCC vcc "VDDD" "VDD!" "vdd!" "VCC!" "vcc!" AVDD DVDD
LVS GROUND NAME GND gnd VSS vss "GNDD" "GND!" "gnd!" "VSS!" "vss!" AVSS DVSS
LVS ISOLATE SHORTS YES CELL PRIMARY
LVS ALL CAPACITOR PINS SWAPPABLE NO

// LVS SHOW SEED PROMOTIONS YES
// LVS SHOW SEED PROMOTIONS MAXIMUM 50

