// 
// 9.1 CALIBRE DRC runset inputs:
//        The user should run the runset on a stream format (binary) file representing
//        the graphic database.
// 
// 9.2 CALIBRE DRC runset
//     
//	In order to Run DRC According to this runset, It should be Included to the Main SL Runset ( According to DR20018SL Spec. ). 
//
// 

LAYER DPAV 2666
LAYER MAP 77 datatype 60 2666


_01AD {
    @01AD: DEV_AREA;a_bitcell layer should be drawn in input layout for Correct DRC Check.
    bulk not interact DPAV
}

_09AD {
    @09AD: DEV_AREA a_bitcell Shape Should be Rectangular .
    X=rectangle (flatten DPAV)
    DPAV not X	
}

_10AD {
    @10AD: Enclosure of DEV_AREA;a_bitcell over N+ Gate,Min 0.60.
    X=(GC not interact WN) and XN
    Y=AA and X 
    enclosure Y DPAV <0.60 region abut<90 proj >0 
}

_11AD {
    @11AD: Enclosure of DEV_AREA;a_bitcell over N+ Active, Min 0.23.
    X=(GC not interact WN) and (XN and DPAV)	
    Y=NSDG interact X <2
    enclosure Y DPAV <0.23 region singular abut<90  proj >0
 
}

_12AD {
    @12AD: Enclosure of DEV_AREA;a_bitcell over P+ Active,Min 0.005. 
       enclosure pdiff DPAV <0.005 region singular abut <90  proj >0 
 
}

_13AD {
    @13AD: DEV_AREA;a_bitcell cannot cut Contact.
    CS cut DPAV
}

_14AD {
    @14AD: DEV_AREA;a_bitcell cannot cut Via2/Via3 .
    V2 cut DPAV
#ifndef 3LM
    V3 cut DPAV
#endif
}

_15AD {
    @15AD: Internal Bitcell GC/M1 polygon, crossing or touchings DEV_AREA;a_bitcell , cannot form a 45 degrees shape with marking layer edge .
enc GC DPAV >0< 0.05 abut region intersecting only angled ==1
enc M1 DPAV >0< 0.05 abut region intersecting only angled ==1
}

DA02=(size ( flatten DPAV) by 0.2) not (flatten DPAV) 

CU03AD {
    @CU03AD: External Bitcell GC/M1 polygon, crossing or touchings DEV_AREA;a_bitcell , cannot form a 45 degrees shape with marking layer edge .
ext GC DPAV >0< 0.05 abut region intersecting only angled ==1
ext M1 DPAV >0< 0.05 abut region intersecting only angled ==1
}

CU04AD {
    @CU04AD: Non Orthogonal corners, orthogonal inner corners, are not allowed for GC/M1 in distance of 0.18 from bitcell edge.
   GCf=GC and ((size ( flatten DPAV) by 0.5) not (size ( flatten DPAV) by -0.5))
   M1f=M1 and ((size ( flatten DPAV) by 0.5) not (size ( flatten DPAV) by -0.5))
   X45=(ext GCf <0.005 abut == 45 region) or (int GCf <0.005 abut == 45 region)
   X90= ext GCf <0.005 abut == 90 region
   X135=(ext GCf <0.005 abut == 135 region) or (int GCf <0.005 abut == 135 region)
   XX= (size (flatten DPAV) by 0.175) not (flatten DPAV)
   (X90 or ( X45 or X135)) interact XX
   ext  (X90 or ( X45 or X135)) DPAV < 0.175  abut region singular opposite proj>0
   Y45=(ext M1f <0.005 abut == 45 region) or (int M1f <0.005 abut == 45 region)
   Y90= ext M1f <0.005 abut == 90 region
   Y135=(ext M1f <0.005 abut == 135 region) or (int M1f <0.005 abut == 135 region)
   (Y90 or ( Y45 or Y135)) interact XX
   ext  (Y90 or ( Y45 or Y135)) DPAV < 0.175  abut region singular opposite proj>0 
   X1=GC and ((size (flatten DPAV) by 0.18) not (flatten DPAV))
   X2=M1 and ((size (flatten DPAV) by 0.18) not (flatten DPAV))
   (expand edge (angle X1 != 90) by 0.005) not (expand edge (angle X1 == 0) by 0.005)
   (expand edge (angle X2 != 90) by 0.005) not (expand edge (angle X2 == 0) by 0.005)
}

CU05AD {
    @CU05AD: min distance between Via2/Via3 and DEV_AREA;a_bitcell , is 0.2 micron .
   DA02 and V2
#ifndef 3LM
   DA02 and V3
#endif
}

CU06AD {
    @CU06AD: min distance between contact and DEV_AREA;a_bitcell , is 0.2 micron.
   DA02 and CS
}
