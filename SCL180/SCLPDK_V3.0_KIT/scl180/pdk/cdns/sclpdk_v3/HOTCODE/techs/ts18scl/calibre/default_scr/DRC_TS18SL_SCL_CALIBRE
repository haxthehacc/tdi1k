		@MFC.N.4: M(x+1) above MC1x (x=3,4,5,6) is not allowed, this rule not applicable for single metal devices
		last_metal = (MT or MT3) or MTOP
		#ifdef 4LM //{
			DEV_mfc interact (last_metal interact cm3)
		#else
			DEV_mfc interact (M4 interact cm3)
		#endif //}
		#ifdef 5LM //{
