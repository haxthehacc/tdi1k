		}
	#endif
	MFC.N.8 {
	    @MFC.N.8: Design having "mix" of different MFC dielectrics (USG and FSG) is NOT allowed. ( MFC.N.8 ).
		(DEV_mfc not interact DEV_cap) interact (bulk interact (DEV_mfc and DEV_cap))
		(DEV_mfc and DEV_cap) interact (bulk interact (DEV_mfc not interact DEV_cap))	
	}
