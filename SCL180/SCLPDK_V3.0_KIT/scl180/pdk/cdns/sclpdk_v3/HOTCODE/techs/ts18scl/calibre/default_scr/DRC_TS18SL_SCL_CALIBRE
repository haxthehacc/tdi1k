	MFC.L.1 {
	    @MFC.L.1: Length Of Metal Fringe Capacitor , min 1.1 ( MFC.L.1 ).
		cm3456 = (cm3 or cm4) or cm5
		cm456 = cm4 or cm5
		cm56 = copy cm5 
		length (M1 inside edge cm3456 ) < 1.1
		length (M2 inside edge cm3456 ) < 1.1
		length (M3 inside edge cm3456 ) < 1.1
		length (M4 inside edge cm456) < 1.1
		length (M5 inside edge cm56) < 1.1
	}
	MFC.N.1 {
		@MFC.N.1: Capacitors fingers MUST be stacked (alternating terminals). Capacitor fingers that are not stacked are not allowed.	
		M1_check = M1_cm not (expand edge (M1_cm outside edge M2) in by 0.015)
		M1_check xor M2_cm
		M2_cm xor M3_cm
		(M3_cm interact M4) xor M4_cm
		(M4_cm interact M5) xor M5_cm
	}
	MFC.N.2 {
	    @MFC.N.2: Number of Fringe capacitor finger pairs , min 4 ( MFC.N.2 ).
		cm3 interact Finger_cm3 < 8
		cm4 interact Finger_cm4 < 8
		cm5 interact Finger_cm5 < 8
	}
	MFC.N.3 {
	    @MFC.N.3: Metal edges , compliying with rules MF.W.1 and MF1.W.2 must be 
	    @internally coincident with DEV_AREA(mfc) marking layer ( MFC.N.3 ).
		M1_edge_cm = M1 not outside edge cm
		M2_edge_cm = M2 not outside edge cm
		M3_edge_cm = M3 not outside edge cm
		M4_edge_cm = M4 not outside edge cm
		M5_edge_cm = M5 not outside edge cm
		xx_m1_cm = expand edge ((int (M1_edge_cm) == 0.31 para only) coin in edge cm) by 0.005
		Finger_cm_all not interact xx_m1_cm
		xx_m2_cm = expand edge ((int (M2_edge_cm) == 0.28 para only) coin in edge cm) by 0.005
		Finger_cm_all not interact xx_m2_cm
		#ifdef 4LM_sep //{
			xx_m3_cm = expand edge ((int (M3_edge_cm) == 0.28 para only) coin in edge cm) by 0.005
			(Finger_cm_all interact m3) not interact xx_m3_cm
		#endif //}
		#ifdef 5LM_sep //{
			xx_m4_cm = expand edge ((int (M4_edge_cm) == 0.28 para only) coin in edge cm) by 0.005
			(Finger_cm_all interact m4) not interact xx_m4_cm
		#endif //}
		#ifdef 6LM_sep //{
			xx_m5_cm = expand edge ((int (M5_edge_cm) == 0.28 para only) coin in edge cm) by 0.005
			(Finger_cm_all interact m5) not interact xx_m5_cm
		#endif //}
	}
