EPF.W.1 {
	@EPF.W.1: For Type-1: Width of fuse , exact	0.20
	@This rule is NOT applicable under (77;108) DEV-AREA blow_up(bp)
	int fuse_1 < 0.2 region singular abut < 90
	size fuse_1 by 0.1 underover
}
EPF.L.1 {
	@EPF.L.1: For Type-1: Length of fuse , exact 2
	@This rule is NOT applicable under (77;108) DEV-AREA blow_up(bp)
	fuse_l = ((expand edge fuse_1 out by 0.005) not GC) coin edge fuse
	length fuse_l < 2
	length fuse_l > 2
}
EPF.D.1 {
	@EPF.D.1: Distance between two fuses , min 3.
	err = (ext fuse < 3.0 region singular abut<90) interact SPC_fe > 1
	copy err
	#ifdef DFM_CHECK
		distance_err_P = expand edge (err coin edge fuse) outside by 0.001
		distance_err = ext distance_err_p < 3.0 singular abut > 0 < 90
		distance_err_rdb = DFM PROPERTY distance_err [err_distance = ew(distance_err)] [widen_by = 3.0 - ew(distance_err)]
		DFM RDB distance_err_rdb 
		COMMENT "EPF.D.1: Distance between two fuses, min 3."
	#endif
}
EPF.D.2 {
	@EPF.D.2: M1 is not allowed over the ePolyFuse element.
	@For DRC purposes, check distance of M1(lc) to the ePolyFuse size 0.5um/side. Overlap is NOT allowed. 
	M1 and (size fuse by 0.5)
}
EPF.N.1 {
	@EPF.N.1: The fuse MUST be consist from Salicided undoped Poly.
	@For DRC purposes, 78dt105 that is not interact with {Poly(lc) NOT NS(lc) NOT AA(lc) NOT DEV_AREA(rs) NOT DEV_AREA(cp)} is NOT allowed
	SPC_fe not interact (((((GC and XP) not interact NS)not interact AA)not interact DEV_res)not interact DEV_cap)
}
EPF.N.3 {
	@EPF.N.3: Only one single fuse is allowed inside each fuse marking layer
	SPC_fe interact fuse > 1
}
EPF.N.2 {
	@EPF.N.2: It is NOT allowed for having the following layers over/under the fuse:
	@AA(lc), WN(lc), WB(lc), XN(lc), NS(lc),
	@All metals <= M2 (except M1 that used for terminal connections),
	@PD(lc),
	@Dummy AA, dummy Poly and all <= M3 metal dummies in process (including M1 dummy)
	@For DRC purposes, check that all layers listed above, are NOT interact with 78dt105. 		
	AA interact SPC_fe
	WN interact SPC_fe
	WB interact SPC_fe
	XN interact SPC_fe
	NS interact SPC_fe
	PAD interact SPC_fe
    AAD interact SPC_fe
	GCD interact SPC_fe
	M1D interact SPC_fe
	#ifdef 3LM_sep //{
		M2 interact SPC_fe
		M2D interact SPC_fe
	#endif //}
	#ifdef 4LM_sep //{
		M3D interact SPC_fe
	#endif//}
}
