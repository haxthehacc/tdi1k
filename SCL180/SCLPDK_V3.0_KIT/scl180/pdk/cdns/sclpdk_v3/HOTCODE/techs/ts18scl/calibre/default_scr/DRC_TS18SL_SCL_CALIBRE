	    touch edge MT  DEV_ext
		#ifdef DFM_CHECK
			ext_err = ext MTi DEV_ext < 1 singular abut >0< 90
			ext_error_rdb = DFM PROPERTY ext_err [distance_err = ew (ext_err)] [widen_by = 1- ew(ext_err)]
			DFM RDB ext_error_rdb  
		    COMMENT "EX.N.2.MT: Distance between DEV_AREA(ext) and real MT, Min 1.0 Micron."
		#endif
	}
	EX.D.1 {
		@EX.D.1: Distance from VNN to DEV_AREA(et). VNN cutting DEV_AREA(et) edge is NOPT allowed, min 7.
		external DEV_ext VNN < 7 region singular abut < 90
		#ifdef DFM_CHECK
			ext_err = external DEV_ext VNN < 7 singular abut < 90	
			ext_error_rdb = DFM PROPERTY ext_err [distance_err = ew(ext_err)] [widen_by = 7- EW(ext_err)]
			DFM RDB ext_error_rdb 
			COMMENT "EX.D.1: Distance from VNN to DEV_AREA(et). VNN cutting DEV_AREA(et) edge is NOPT allowed, min 7."
		#endif
	}
#endif //}
