drDefinePacket(
;( DisplayName  PacketName           Stipple    LineStyle  Fill       Outline    [FillStyle])
 ( display      WPD_logic            stipple0   dashed     yellow     yellow     stipple   )
 ( display      WPD_mark             stipple14  lineStyle6 yellow     yellow     outlineStipple)
 ( display      WP_logic             blank      lineStyle0 green      green      outline   )
 ( display      WP_mark              dot2       lineStyle6 cyan       green      outlineStipple)
 ( display      WP_cap               stipple11  solid      green      green      outlineStipple)
 ( display      WN_logic             viap       lineStyle0 magenta    magenta    outlineStipple)
 ( display      WN_mark              stipple7   solid      magenta    magenta    outlineStipple)
 ( display      WN_drc               stipple5   solid      magenta    magenta    outlineStipple)
 ( display      WN_opc               dot1       dashed     pink       pink       outline   )
 ( display      WN_dio               stipple10  solid      cyan       cyan       outlineStipple)
 ( display      WN_vss               stipple8   dashed     silver     silver     outlineStipple)
 ( display      WB_logic             dot2       solid      red        red        outlineStipple)
 ( display      WB_mark              blank      solid      green      red        outline   )
