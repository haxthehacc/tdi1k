;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;  Load the user specific EMX config file
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
if( InitPath = getShellEnvVar( "RDS_ETC") then
  load(strcat(InitPath "/templates/rds_emxconfig.il"))
 else 
    printf("ERROR: system variable \"RDS_ETC\" is not set.\n");
    printf("Initialization aborted!!\n");
    printf("Exit from the Cadence environment, type cdsprj ProjID, and then run the tool again!\n"); 
)
; 
