 ( display       dots         1          (1 0 0 ) )
 ( display       dashDot      1          (1 1 1 0 0 1 0 0 ) )
 ( display       shortDash    1          (1 1 0 0 ) )
 ( display       doubleDash   1          (1 1 1 1 0 0 1 1 0 0 ) )
 ( display       thickLine    3          (1 1 1 ) )
 ( display       hidden       1          (1 0 0 0 ) )
 ( display       lineStyle0   1          (1 ) )
