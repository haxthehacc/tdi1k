-- library containing pins, extracted views, and other fundamental stuff
DEFINE cds_generic 	$RDS_CDSLIBS/cds_generic

-- Cadence provided libraries
-- Include DFII default library set
-- basic, US_8ths
INCLUDE $(inst_root_with:tools/dfII/bin/virtuoso)/tools/dfII/etc/cdsDotLibs/composer/cds.lib
-- analogLib, functional
INCLUDE $(inst_root_with:tools/dfII/bin/virtuoso)/tools/dfII/etc/cdsDotLibs/artist/cds.lib
-- rfLib, rfExamples, ahdlLib
INCLUDE $(inst_root_with:tools/dfII/bin/virtuoso)/tools/dfII/etc/cdsDotLibs/spectre/cds.lib
DEFINE sbaLib $(inst_root_with:tools/dfII/bin/virtuoso)/tools/dfII/etc/cdslib/artist/sbaLib

-- Libaray for Jazz sheet Border
DEFINE sheetBorder	$RDS_CDSLIBS/sheetBorder

-- Jazz Libraries: technology libraries
INCLUDE   $RDS_CDSLIBS/$RDS_CDS_TECH/technology.lib

-- SNA
SOFTDEFINE substrateLib $CDSHOME/share/sna/etc/cdslib/substrateLib

-- ADS Libraries for RFDE
SOFTINCLUDE $RFDE_CDS_VERSION/rfde.lib
