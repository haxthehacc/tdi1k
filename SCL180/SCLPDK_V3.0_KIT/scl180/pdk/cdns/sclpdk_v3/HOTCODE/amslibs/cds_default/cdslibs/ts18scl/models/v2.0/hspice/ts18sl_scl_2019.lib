* p5v mapping equations
+ lvar_p5v = '(-1/2) * lvaro_p5v * (1 + lvarl_p5v * 1/0.13)'
+ dldd_p5v = 'dNovByNov_p5v * lvar_p5v'
+ ddw_p5v = '-1*(dacd_p5v/2)'
