* p5v mismatch
+ m_dSrBySr_p5v = '0.00575*0.5'
+ m_dpcd_p5v = 1.10000e-09
+ m_dacd_p5v = '5.00000e-11/2.5'
+ m_dtox_p5v = 2.01250e-11
+ m_dvfb_p5v = '1.55000e-02*0.6'
