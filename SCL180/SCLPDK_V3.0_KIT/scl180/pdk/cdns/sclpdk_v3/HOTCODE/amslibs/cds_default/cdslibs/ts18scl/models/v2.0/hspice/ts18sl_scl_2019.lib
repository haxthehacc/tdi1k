*SCL CONFIDENTIAL*
* --------------------------------------------------------------------
*date:       Dec, 2022
****************************************************************
******************************************************************
*Content: 
*======================================================================================================
*       Device                   *      library/corners           *     model              *  Comment |
*======================================================================================================
*------------------------------------------------------------------------------------------------------
* 1.8v (HVt)LowLeakage Mosfet models * tt_18dll,ss_18dll,ff_18dll,*     n18hvtb3,p18hvtb3 *          |
*                                * sf_18dll,fs_18dll              *                        *          |
*------------------------------------------------------------------------------------------------------
*------------------------------------------------------------------------------------------------------
* 5v   Mosfet                    * tt_5v,ff_5v,ss_5v,sf_5v,fs_5v  *     n5v,p5v            *          |
*------------------------------------------------------------------------------------------------------
* S/D Diodes                     *                                *                                   |  
*                                *       diodesnew /*name changed * dn50,dp50              * 5.0V     |  
* 					             *                                * 								  |
*                                *                                * 								  |
*                                *                                * 								  |
*------------------------------------------------------------------------------------------------------
* Native Mosfet                  * 					          *                                   |
*                                *  			                  *									  |	
*                                * tt_n5v,ff_n5v,ss_n5v 	  * nath5v                 *  5.0V        |
*                                * sf_n5v,fs_n5v
*------------------------------------------------------------------------------------------------------
* BJTs                           * tt_bjt,ff_bjt,ss_bjt           * vd10,vd5,vd2           * PNP      |
*                                *                                * vdn5,                          *  |
*------------------------------------------------------------------------------------------------------
* MIM Capacitors                 * mimcap_typ,mimcap_high,        * cmim_sq,                           |
*                                * mimcap_low                     *                                    | 
*                                *                                *                                  * |
*------------------------------------------------------------------------------------------------------
* Metal Fringe Capacitors        * mfc_typ,mfc_high,mfc_low       * usgcm52t, usgcm53t   * 6LM        |
*                                *                                *                                   |
*                                *                                * 				   	 *            | 
*                                *                                *                      *            |
*                                *                                * usgcm32t,usgcm33t   * 4LM         |
*                                *                                *                *                  |
*------------------------------------------------------------------------------------------------------
* Resistors                      * res2tnew_typ,res2tnew_high,    * nasr2t,pasr2t,rm1,rm2, *          |/*adding 'new' on corner name for smooth integration of 2 files
*                                * res2tnew_low                   * rm3,rm4,rm5,rml,rmt,   * 2Terminal|/*Only mr22t is retained, rest removed in this file */
*                                *                                * rmt3(REMOVED),mr22t,rnmpoly2t,  * |
*                                *                                * rnplus2t,rnwellaa2t,   *          |
*                                *                                * rnwellsti2t,rphpoly2t, *          |
*                                *                                * rplpoly2t,rpmpoly2t,   *          |
*                                *                                * rpplus2t,rnlpoly2t     *          |
*                                *---------------------------------------------------------------------
*                                * res3tnew_typ,res3tnew_high,    * nasr3t,pasr3t,rnlpoly3t*          |/*adding 'new' on corner name for smooth integration of 2 files
*                                * res3tnew_low                   * rnmpoly3t,rnplus3t,    * 3Terminal|/*Only mr23t is retained, rest removed in this file */
*                                *                                * rnwellaa3t,rnwellsti3t,*          |
*                                *                                * rphpoly3t,rplpoly3t,   *          |
*                                *                                * rpmpoly3t,rpplus3t,    *          |
*                                *                                * mr23t                  *          |
*------------------------------------------------------------------------------------------------------
*======================================================================================================
* Please, refer to accompanying documentation for models usage guidelines and models applicability
******************************************************************
*
*Usage:	    Netlist should include statement:
*	    .lib 'path_to_model/ts18sl_scl_2019.lib' diodes ( for diodes, 3T resistors, 3T accumulation caps)
*	    .lib 'path_to_model/ts18sl_scl_2019.lib' your_corner
*	    change the path of the lib according to its actual path. diodes library should
*           be included for 3T models.
*
*
*
* Note regarding hdif: hdif=0.15e-6 is used to define a default value of source/drain
* junction capacitances when their dimensions (as,ps,ad,pd) are not specified in netlist.
* For accurate parasitic capacitance modeling it is strongly recomended to use the mos parasitic diode
* parameters as, ps, ad, pd  based on the actual device layout dimensions as netlisted from the PDK.
********************************************************************


*
*
.lib diodesnew
*
* diode model
*

***********5V N+Pwell Diode****************
* hspice level-3
.model dn50 d
+ level=3  is= 1.87e-07 jsw= 1.26e-13
+ n= 1  rs= 7.77e-12  ik=2.11E+007
+ ikr = 0.00 vb= 11.5  ibv= 0.001
+ lm = 0.00  lp = 0.00  wm = 0.00
+ wp = 0.00  xm = 0.00  xoi = 1.00e+04
+ xom = 1.00e+04  xp = 0.00 xw = 0.00
+ trs=0  cta= 9.52e-04  ctp= 3.65e-04
+ eg=1.16  tcv= -0.0006  gap1=4.73e-04
+ gap2=1.11e+03  tlev=1  fc=0
+ tref=25.0  tlevc=1  fcs = 0                 
+ tpb = 0.001385  tphp= 0.001153  xti= 3
+ cj= 0.0009592  mj= 0.2997  pb= 0.5929
+ cjsw=2.66E-011  mjsw=0.066  php=1.372
+ tt=5e-09



***********5V P+Nwell Diode****************
* hspice level-3
.model dp50 d
+ level=3  is= 2.262e-007  jsw=  1.142e-013
+ n= 1  rs= 5.24e-12 ik=2.11E+007
+ ikr = 0.00  vb= 11.5  ibv= 0.005105
+ lm = 0.00  lp = 0.00  wm = 0.00
+ wp = 0.00  xm = 0.00  xoi = 1.00e+04
+ xom = 1.00e+04  xp = 0.00 xw = 0.00
+ trs=0  cta= 0.0006349  ctp= 0.0007433
+ eg=1.16  tcv=-0.0006  gap1=4.73e-04
+ gap2=1.11e+03  tlev=1  fc=0
+ tref=25.0  tlevc=1    fcs = 0               
+ tpb= 0.000968  tphp=0.0004376  xti= 3
+ cj= 0.0009174  mj= 0.3234  pb= 0.5548
+ cjsw= 5.11e-011 mjsw= 0.2166  php= 1.192
+ tt=5e-09


**************************************************************

.endl diodesnew

