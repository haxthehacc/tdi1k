***************************************************************************
.lib h5tnative
.PARAM
* 5v native fet process constants
+ type_n5p0_vt0=1
+ nch_n5p0_vt0=3.64e+15
+ tox_n5p0_vt0=1.10000e-08
+ lint_n5p0_vt0=-2.63098e-08
+ ll_n5p0_vt0=1.58412e-13
+ lw_n5p0_vt0=-1.74264e-13
+ lwl_n5p0_vt0=-5.44076e-20
+ lln_n5p0_vt0=1.00000
+ lwn_n5p0_vt0=1.00000
+ wint_n5p0_vt0=6.86624e-09
+ wl_n5p0_vt0=-8.35844e-14
+ ww_n5p0_vt0=-3.97551e-14
+ wwl_n5p0_vt0=-2.95405e-20
+ wln_n5p0_vt0=1.00000
+ wwn_n5p0_vt0=1.00000
* Mapping Equations for process corners 
+ dldd_n5p0_vt0='dnovbynov_n5p0_vt0 * lint_n5p0_vt0'
+ ddw_n5p0_vt0='-1*(dacd_n5p0_vt0/2)'
+ ddl_n5p0_vt0='dldd_n5p0_vt0 + -1*(dpcd_n5p0_vt0/2)'
+ knch_n5p0_vt0='1 + dnchbynch_n5p0_vt0'
+ kcj_n5p0_vt0='1 + 0.5*dnchbynch_n5p0_vt0'
+ kcjsw_n5p0_vt0='1 + 0.5*dnchbynch_n5p0_vt0'
+ kcjswg_n5p0_vt0='1 + 0.5*dnchbynch_n5p0_vt0'
+ ku0_n5p0_vt0='1 - dsrbysr_n5p0_vt0'
+ krdsw_n5p0_vt0='1 - dnovbynov_n5p0_vt0'
+ vbi_n5p0_vt0='vthermal * log((nch_n5p0_vt0 * 1e6 * 1e26)/(ni*ni))'
+ phis_n5p0_vt0='vthermal * log(nch_n5p0_vt0/ni)'
+ ddvt0_n5p0_vt0='type_n5p0_vt0 * dvfbl_n5p0_vt0/(vbi_n5p0_vt0 - phis_n5p0_vt0)'
+ dnlx_n5p0_vt0='dnpck_n5p0_vt0'
+ ddvt2_n5p0_vt0='dnchl_n5p0_vt0 + dnpck_n5p0_vt0'
+ ddvt0w_n5p0_vt0='dvfblw_n5p0_vt0'
+ ddvt2w_n5p0_vt0='dnchlw_n5p0_vt0'
+ dk3b_n5p0_vt0='dnchw_n5p0_vt0'
+ dnch_n5p0_vt0='nch_n5p0_vt0 * dnchbynch_n5p0_vt0'
+ dvth0_dnch_n5p0_vt0='(type_n5p0_vt0*2*vthermal)/(nch_n5p0_vt0*1e6) + (type_n5p0_vt0*tox_n5p0_vt0/eox) * sqrt((esi*kboltz*tem)/(nch_n5p0_vt0*1e6)) * (1/sqrt(log(nch_n5p0_vt0*1e6/ni)) + sqrt(log(nch_n5p0_vt0*1e6/ni)))'
+ dvth0_dtox_n5p0_vt0='(type_n5p0_vt0*2/eox) * sqrt(esi*kboltz*tem*nch_n5p0_vt0*1e6*(log((nch_n5p0_vt0*1e6)/ni)))'
+ dvth0_nch_n5p0_vt0='dvth0_dnch_n5p0_vt0*1e6*dnch_n5p0_vt0'
+ dvth0_tox_n5p0_vt0='dvth0_dtox_n5p0_vt0 * dtox_n5p0_vt0'
+ dvth0_n5p0_vt0='dvfb_n5p0_vt0 + dvth0_nch_n5p0_vt0 + dvth0_tox_n5p0_vt0'
+ kk1_nch_n5p0_vt0='1 + 0.5*dnchbynch_n5p0_vt0'
+ kk1_tox_n5p0_vt0='1 + dtox_n5p0_vt0/tox_n5p0_vt0'
+ kk1_n5p0_vt0='kk1_nch_n5p0_vt0 * kk1_tox_n5p0_vt0'
+ kcovlp_n5p0_vt0='tox_n5p0_vt0/(tox_n5p0_vt0 + dtox_n5p0_vt0)'

.subckt nath5v d g s b l=1u w=1u nrs=1 nrd=1 m=1 as=0 ad=0 ps=0 pd=0
+Aw='log(w*10)/abs(log(w*10))' 
+myHdif= '0.5*(0.15*(1+Aw)+0.15e-6*(1-Aw))'
+aseff = 'int(1-as*1.5e-7/myHdif)*2*w*myHdif+as'
+pseff = 'int(1-ps*1.5e-7/myHdif)*(2*w+4*myHdif)+ps'
+adeff = 'int(1-ad*1.5e-7/myHdif)*2*w*myHdif+ad'
+pdeff = 'int(1-pd*1.5e-7/myHdif)*(2*w+4*myHdif)+pd'

m d g s b nath5vstat  w=w l=l  as=aseff ps=pseff ad=adeff pd=pdeff nrs=nrs nrd=nrd 
.flat m

.MODEL nath5vstat NMOS
+ LEVEL=49
+ version=3.24
+ binunit=2
+ mobmod=1
+ capmod=3
+ nqsmod=0
