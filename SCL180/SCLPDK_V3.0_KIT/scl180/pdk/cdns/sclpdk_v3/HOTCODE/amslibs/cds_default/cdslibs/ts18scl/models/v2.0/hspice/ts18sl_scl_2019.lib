.subckt p18hvtb3 d g s b w=10e-6 l=0.18e-6 nf=1 slices=1 cur=0 as=0 ad=0 ps=0 pd=0 m=1
.param 
+ Al= 'log(l*10)/abs(log(l*10))'
+ UnScale= '0.5*((1+Al)*1e6 + (1-Al))'
+ myHdif= '0.5*(0.15*(1+Al)+0.15e-6*(1-Al))'
+ aseff = '(int(1-as*1.5e-7/myHdif)*2*w*myHdif+as)'
+ pseff = '(int(1-ps*1.5e-7/myHdif)*(2*w+4*myHdif)+ps)'
+ adeff = '(int(1-ad*1.5e-7/myHdif)*2*w*myHdif+ad)'
+ pdeff = '(int(1-pd*1.5e-7/myHdif)*(2*w+4*myHdif)+pd)'
+ wf='w/UnScale'
+ lf='l/UnScale'
+ nsnd='nf*slices'
* Local mismatch parameters
+ mis_poly_cd_18=AGAUSS(0,1,1) mis_active_cd_18=AGAUSS(0,1,1) mis_tox_18=AGAUSS(0,1,1)
+ mis_sr_18=AGAUSS(0,1,1) mis_vfb_p18hvt=AGAUSS(0,1,1) mis_nch_p18hvt=AGAUSS(0,1,1)
+ eff_wf = '(wf + wvaro_p18hvt*(1+wvarl_p18hvt*1e-6/lf)*(1+wvarw_p18hvt*1e-6/wf) - 2*wot_p18hvt)*1e6'
+ eff_lf = '(lf + lvaro_p18hvt*(1+lvarl_p18hvt*1e-6/lf)*(1+lvarw_p18hvt*1e-6/wf) - 2*lap_p18hvt)*1e6'
+ sqrt_eff_wf = 'sqrt(m*nf*eff_wf)'
+ sqrt_eff_lf = 'sqrt(eff_lf)'
+ mm_dtox = 'm_dtox_p18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_tox_18'
+ mm_dvfb = 'm_dvfb_p18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_vfb_p18hvt'
+ mm_kuo = '1 - m_dSrBySr_p18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_sr_18'
+ mm_knsub = '1 + m_dNsubByNsub_p18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_nch_p18hvt'
+ mm_ddl = '(-1/2)*(m_dpcd_p18hvt/sqrt_eff_wf) * mis_poly_cd_18'
+ mm_ddw = '(-1/2)*(m_dacd_p18hvt/sqrt_eff_lf) * mis_active_cd_18'
* Combined stat. and mismatch parameters
+ dtox_p18hvts = 'dtox_p18hvt + mm_dtox'
+ ddl_p18hvts = 'ddl_p18hvt + mm_ddl'
+ ddw_p18hvts = 'ddw_p18hvt + mm_ddw'
+ kuo_p18hvts = 'kuo_p18hvt * mm_kuo'
+ dvfb_p18hvts = 'dvfb_p18hvt + mm_dvfb'
+ knsub_p18hvts = 'knsub_p18hvt * mm_knsub'

mp18hvtb3 d g s b p18hvtb3s l=l w=w m=nsnd 
+ as=aseff ps=pseff ad=adeff pd=pdeff 

