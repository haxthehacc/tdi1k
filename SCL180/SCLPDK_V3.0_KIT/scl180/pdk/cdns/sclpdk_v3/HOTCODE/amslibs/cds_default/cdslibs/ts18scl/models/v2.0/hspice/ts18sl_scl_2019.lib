.lib mos18dll

*Hspice library for SCL18sl 1.8 HVT fets - PSP

.param
* n18hvtb3 mismatch
+ m_dSrBySr_n18hvt = 0.015
+ m_dpcd_n18hvt = 1n
+ m_dacd_n18hvt = 0.5n
+ m_dtox_n18hvt = 10p
+ m_dvfb_n18hvt = 18m
+ m_dNsubByNsub_n18hvt =25m
* n18hvtb3 dl/dw
+ wot_n18hvt = 6.060928700000001e-08
+ wvaro_n18hvt = 7.351000000000000e-08
+ wvarl_n18hvt = 1.015000000000000e-03
+ wvarw_n18hvt = 1.605000000000000e-01
+ lap_n18hvt = 8.793533760000000e-09
+ lvaro_n18hvt = 2.580000000000000e-08
+ lvarl_n18hvt = -1.540000000000000e-01
+ lvarw_n18hvt = 1.111000000000000e-01
* n18hvtb3 mapping equations
+ lvar_n18hvt = '(-1/2) * lvaro_n18hvt * (1 + lvarl_n18hvt * 1/0.13)'
*+ dldd_n18hvt = 'dNovByNov_n18hvt * lap_n18hvt'
+ dldd_n18hvt = 'dNovByNov_n18hvt * lvar_n18hvt'
+ ddw_n18hvt = '-1*(dacd_n18hvt/2)'
+ ddl_n18hvt = 'dldd_n18hvt - dpcd_n18hvt/2'
+ knsub_n18hvt = '1 + dNsubByNsub_n18hvt'
+ kcj_n18hvt = '1 + 0.5*dNsubByNsub_n18hvt'
+ kcjsw_n18hvt = '1 + 0.5*dNsubByNsub_n18hvt'
+ kcjswg_n18hvt = '1 + 0.5*dNsubByNsub_n18hvt + dNovByNov_n18hvt'
+ kuo_n18hvt = '1 - dSrBySr_n18hvt'
+ krdsw_n18hvt = '1 - dNovByNov_n18hvt'
+ knov_n18hvt = '1 + dNovByNov_n18hvt'
+ kalp_n18hvt = '1 - 100*dNsubByNsub_n18hvt'
+ kcfl_n18hvt = '1 + 10*dNsubByNsub_n18hvt' 

* p18hvtb3 mismatch
+ m_dSrBySr_p18hvt = 0.007
+ m_dpcd_p18hvt = 1n
+ m_dacd_p18hvt = 0.5n
+ m_dtox_p18hvt = 10p
+ m_dvfb_p18hvt = 9.5m
+ m_dNsubByNsub_p18hvt =10m
* p18hvtb3 dl/dw
+ wot_p18hvt = 6.032596405000001e-08
+ wvaro_p18hvt = 1.243000000000000e-08
+ wvarl_p18hvt = 1.894000000000000e-02
+ wvarw_p18hvt = 2.076000000000000e+00
+ lap_p18hvt = 2.356945075000000e-09
+ lvaro_p18hvt = 1.710000000000000e-08
+ lvarl_p18hvt = -1.049000000000000e-01
+ lvarw_p18hvt = 4.684000000000000e-01
* p18hvtb3 mapping equations
+ lvar_p18hvt = '(-1/2) * lvaro_p18hvt * (1 + lvarl_p18hvt * 1/0.13)'
*+ dldd_p18hvt = 'dNovByNov_p18hvt * lap_p18hvt'
+ dldd_p18hvt = 'dNovByNov_p18hvt * lvar_p18hvt'
+ ddw_p18hvt = '-1*(dacd_p18hvt/2)'
+ ddl_p18hvt = 'dldd_p18hvt - dpcd_p18hvt/2'
+ knsub_p18hvt = '1 + dNsubByNsub_p18hvt'
+ kcj_p18hvt = '1 + 0.5*dNsubByNsub_p18hvt'
+ kcjsw_p18hvt = '1 + 0.5*dNsubByNsub_p18hvt'
+ kcjswg_p18hvt = '1 + 0.5*dNsubByNsub_p18hvt + dNovByNov_p18hvt'
+ kuo_p18hvt = '1 - dSrBySr_p18hvt'
+ krdsw_p18hvt = '1 - dNovByNov_p18hvt'
+ knov_p18hvt = '1 + dNovByNov_p18hvt'
+ kalp_p18hvt = '1 - 100*dNsubByNsub_p18hvt'
+ kcfl_p18hvt = '1 + 10*dNsubByNsub_p18hvt' 

.subckt n18hvtb3 d g s b w=10e-6 l=0.18e-6 nf=1 slices=1 cur=0 as=0 ad=0 ps=0 pd=0 m=1
.param 
+ Al= 'log(l*10)/abs(log(l*10))'
+ UnScale= '0.5*((1+Al)*1e6 + (1-Al))'
+ myHdif= '0.5*(0.15*(1+Al)+0.15e-6*(1-Al))'
+ aseff = '(int(1-as*1.5e-7/myHdif)*2*w*myHdif+as)'
+ pseff = '(int(1-ps*1.5e-7/myHdif)*(2*w+4*myHdif)+ps)'
+ adeff = '(int(1-ad*1.5e-7/myHdif)*2*w*myHdif+ad)'
+ pdeff = '(int(1-pd*1.5e-7/myHdif)*(2*w+4*myHdif)+pd)'
+ wf='w/UnScale'
+ lf='l/UnScale'
+ nsnd='nf*slices'
* Local mismatch parameters
+ mis_poly_cd_18=AGAUSS(0,1,1) mis_active_cd_18=AGAUSS(0,1,1) mis_tox_18=AGAUSS(0,1,1)
+ mis_sr_18=AGAUSS(0,1,1) mis_vfb_n18hvt=AGAUSS(0,1,1) mis_nch_n18hvt=AGAUSS(0,1,1)
+ eff_wf = '(wf + wvaro_n18hvt*(1+wvarl_n18hvt*1e-6/lf)*(1+wvarw_n18hvt*1e-6/wf) - 2*wot_n18hvt)*1e6'
+ eff_lf = '(lf + lvaro_n18hvt*(1+lvarl_n18hvt*1e-6/lf)*(1+lvarw_n18hvt*1e-6/wf) - 2*lap_n18hvt)*1e6'
+ sqrt_eff_wf = 'sqrt(m*nf*eff_wf)'
+ sqrt_eff_lf = 'sqrt(eff_lf)'
+ mm_dtox = 'm_dtox_n18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_tox_18'
+ mm_dvfb = 'm_dvfb_n18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_vfb_n18hvt'
+ mm_kuo = '1 - m_dSrBySr_n18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_sr_18'
+ mm_knsub = '1 + m_dNsubByNsub_n18hvt/(sqrt_eff_wf*sqrt_eff_lf) * mis_nch_n18hvt'
+ mm_ddl = '(-1/2)*(m_dpcd_n18hvt/sqrt_eff_wf) * mis_poly_cd_18'
+ mm_ddw = '(-1/2)*(m_dacd_n18hvt/sqrt_eff_lf) * mis_active_cd_18'
* Combined stat. and mismatch parameters
+ dtox_n18hvts = 'dtox_n18hvt + mm_dtox'
+ ddl_n18hvts = 'ddl_n18hvt + mm_ddl'
+ ddw_n18hvts = 'ddw_n18hvt + mm_ddw'
+ kuo_n18hvts = 'kuo_n18hvt * mm_kuo'
+ dvfb_n18hvts = 'dvfb_n18hvt + mm_dvfb'
+ knsub_n18hvts = 'knsub_n18hvt * mm_knsub'

mn18hvtb3 d g s b n18hvtb3s l=l w=w m=nsnd 
+ as=aseff ps=pseff ad=adeff pd=pdeff 

.flat mn18hvtb3

.model n18hvtb3s nmos 
+ LEVEL=69 GEOMOD=1 BINMOD=0 VERSION=102.5
+ tr = 25.00
+ swigate = 1.000
+ swimpact = 1.000
+ swgidl = 1.000
+ swjuncap = 3.000
+ swnqs = 0
+ qmc = 1.000
+ lvaro = 25.80e-9
+ lvarl = -154.0e-3
+ lvarw = 111.1e-3
+ lap = '0.000 + 8.79353376e-09 + ddl_n18hvts'
+ wvaro = 73.51e-9
+ wvarl = 1.015e-3
+ wvarw = 160.5e-3
+ wot = '0.000 + 60.609287e-09 + ddw_n18hvts'
+ dlq = -65.29e-9
+ dwq = 0.000
+ vfbo = '-978.8e-3 - 0.015744672685 + dvfb_n18hvts'
+ vfbl = '-58.03e-3 - 0.0077964894 + dvfbl_n18hvt'
+ vfbw = '11.74e-3 - 0.02289596998 + dvfbw_n18hvt'
+ vfblw = '-2.522e-3 + 3.595962068e-03 + dvfblw_n18hvt'
+ stvfbo = 964.6e-6
+ stvfbl = 35.38e-3
+ stvfbw = 45.90e-3
+ stvfblw = -5.847e-3
+ toxo = '3.067e-9 + dtox_n18hvts'
+ nsubo = '4.458E+23 * knsub_n18hvts'
+ nsubw = '-21.64e-3 + dnsubw_n18hvt'
+ wseg = 1.630e-9
+ npck = 2.808E+23
+ npckw = -8.979e-6
+ wsegp = 8.068e-6
+ lpck = 7.591e-9
+ lpckw = -13.77e-6
+ fol1 = '-7.863e-3 + dnsubl_n18hvt'
+ fol2 = 17.27e-3
+ vnsubo = -265.6e-3
+ nslpo = 50.00e-3
+ dnsubo = 4.850e-3
+ dphibo = -24.04e-3
+ dphibl = -20.71e-3
+ dphiblexp = 73.69e-3
+ dphibw = 531.2e-6
+ dphiblw = -2.952e-3
+ npo = 1.000E+26
+ npl = -141.7e-3
+ cto = 161.0e-3
+ ctl = 25.81e-3
+ ctlexp = 842.7e-3
+ ctw = -499.3e-6
+ ctlw = -3.012e-3
+ toxovo = '2.496e-9 + dtox_n18hvts'
+ lov = '26.49e-9 + dldd_n18hvt'
+ novo = '2.496E+25 * knov_n18hvt'
+ cfl = 788.9e-6
+ cflexp = 2.080
+ cfw = 0.000
+ cfbo = 289.0e-3
+ uo = '44.69e-3 * 1.0119462702 * kuo_n18hvts'
+ fbet1 = -3.260
+ fbet1w = -37.96e-3
+ lp1 = 8.213e-9
+ lp1w = -22.96e-3
+ fbet2 = -4.791
+ lp2 = 10.40e-9
+ betw1 = -142.1e-3
+ betw2 = 13.92e-3
+ wbet = 1.003e-9
+ stbeto = 1.892
+ stbetl = 10.78e-3
+ stbetw = -30.44e-3
+ stbetlw = -5.811e-3
+ mueo = 452.4e-3
+ muew = -2.683e-3
+ stmueo = 585.1e-3
+ themuo = 1.905
+ stthemuo = 567.5e-3
