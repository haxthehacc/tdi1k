+ mm_dtox = 'm_dtox_p5v/(sqrt_eff_wf*sqrt_eff_lf) * mis_tox'
+ mm_dvfb = '(m_dvfb_p5v/(sqrt_eff_wf*sqrt_eff_lf) + 5e-4) * mis_vfb_p5v'
+ mm_kuo = '1 - (m_dSrBySr_p5v/(sqrt_eff_wf*sqrt_eff_lf) + 0.0007) * mis_sr'
+ mm_knsub = '1 + m_dNsubByNsub_p5v/(sqrt_eff_wf*sqrt_eff_lf) * mis_nch_p5v'
+ mm_ddl = '(-1/2)*(m_dpcd_p5v/sqrt_eff_wf) * mis_poly_cd'
+ mm_ddw = '(-1/2)*(m_dacd_p5v/sqrt_eff_lf) * mis_active_cd'
* Combined stat. and mismatch parameters
+ dtox_p5vs = 'dtox_p5v + mm_dtox'
