+ mis_sr=AGAUSS(0,1,1) mis_vfb_p5v=AGAUSS(0,1,1) mis_nch_p5v=AGAUSS(0,1,1)
+ eff_wf = '(wf + wvaro_p5v*(1+wvarl_p5v*1e-6/lf)*(1+wvarw_p5v*1e-6/wf) - 2*wot_p5v)*1e6'
+ eff_lf = '(lf + lvaro_p5v*(1+lvarl_p5v*1e-6/lf)*(1+lvarw_p5v*1e-6/wf) - 2*lap_p5v)*1e6'
+ sqrt_eff_wf = 'sqrt(m*nf*eff_wf)'
