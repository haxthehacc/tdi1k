*hspice model for 10x10 um vpnp bipolar junction transistor.

.subckt vd10 c b e m=1
.param   
+ area=1  areab=1  areac=1
+ vpnpismatch = agauss(0,1,1)
+ vpnpisematch = agauss(0,1,1)
+ is_mm  = '(1-1.8375e-03*vpnpismatch/sqrt(m))'
+ ise_mm = '(1-1.5500e-01*vpnpisematch/sqrt(m))'

qvd10  c b e vpd10 area=area areab=areab areac=areac

.flat qvd10

.model vpd10 pnp level=1  
+ is = '7.047e-18 *is_mm'
+ bf = '0.8790*3.08*bf_vd10' 
+ nf = '0.9802*nf_vd10' 
