.subckt n5v d g s b w=0.6e-6 l=0.5e-6 nf=1 slices=1 cur=0 as=0 ad=0 ps=0 pd=0 m=1
.param 
*.PARAM
+Al= 'log(l*10)/abs(log(l*10))'
+UnScale='0.5*((1+Al)*1e6 + (1-Al))'
+myHdif= '0.5*(0.15*(1+Al)+0.15e-6*(1-Al))'
+aseff = '(int(1-as*1.5e-7/myHdif)*2*w*myHdif+as)'
+pseff = '(int(1-ps*1.5e-7/myHdif)*(2*w+4*myHdif)+ps)'
+adeff = '(int(1-ad*1.5e-7/myHdif)*2*w*myHdif+ad)'
+pdeff = '(int(1-pd*1.5e-7/myHdif)*(2*w+4*myHdif)+pd)'
+ wf='w/UnScale'
+ lf='l/UnScale'
+ nsnd='nf*slices'
* Local mismatch parameters
+ mis_poly_cd=AGAUSS(0,1,1) mis_active_cd=AGAUSS(0,1,1) mis_tox=AGAUSS(0,1,1)
+ mis_sr=AGAUSS(0,1,1) mis_vfb_n5v=AGAUSS(0,1,1) mis_nch_n5v=AGAUSS(0,1,1)
+ eff_wf = '(wf + wvaro_n5v*(1+wvarl_n5v*1e-6/lf)*(1+wvarw_n5v*1e-6/wf) - 2*wot_n5v)*1e6'
+ eff_lf = '(lf + lvaro_n5v*(1+lvarl_n5v*1e-6/lf)*(1+lvarw_n5v*1e-6/wf) - 2*lap_n5v)*1e6'
+ sqrt_eff_wf = 'sqrt(m*nf*eff_wf)'
+ sqrt_eff_lf = 'sqrt(eff_lf)'
+ mm_dtox = 'm_dtox_n5v/(sqrt_eff_wf*sqrt_eff_lf) * mis_tox'
+ mm_dvfb = 'm_dvfb_n5v/(sqrt_eff_wf*sqrt_eff_lf) * mis_vfb_n5v'
+ mm_kuo = '1 - (m_dSrBySr_n5v/(sqrt_eff_wf*sqrt_eff_lf) + 0.00045) * mis_sr'
+ mm_knsub = '1 + m_dNsubByNsub_n5v/(sqrt_eff_wf*sqrt_eff_lf) * mis_nch_n5v'
+ mm_ddl = '(-1/2)*(m_dpcd_n5v/sqrt_eff_wf) * mis_poly_cd'
+ mm_ddw = '(-1/2)*(m_dacd_n5v/sqrt_eff_lf) * mis_active_cd'
* Combined stat. and mismatch parameters
+ dtox_n5vs = 'dtox_n5v + mm_dtox'
+ ddl_n5vs = 'ddl_n5v + mm_ddl'
+ ddw_n5vs = 'ddw_n5v + mm_ddw'
+ kuo_n5vs = 'kuo_n5v * mm_kuo'
+ dvfb_n5vs = 'dvfb_n5v + mm_dvfb'
+ knsub_n5vs = 'knsub_n5v * mm_knsub'

mn5v d g s b n5vs l=l w=w m=nsnd 
+ as=aseff ps=pseff ad=adeff pd=pdeff 

