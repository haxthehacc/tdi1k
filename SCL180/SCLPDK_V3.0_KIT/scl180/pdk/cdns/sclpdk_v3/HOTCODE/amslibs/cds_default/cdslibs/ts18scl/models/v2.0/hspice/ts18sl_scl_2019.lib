*                                             
********************************************************************
*0.18 um Accumulation Capacitor models
* Scalable model 
* Includes matching
*                  
********************************************************************
*                                        17 Sept 2006    
********************************************************************


* Metal Fringe Capacitor
* 2 Terminals & 3 Terminals Models
*************************************************************
*Model parameters: 
*	length = length of finger
*	nf     = number of finger PAIRS
*************************************************************

.lib mfc_typ
.param c_den=0.84e-3
.param c_den6=1.01e-3
.param c_den4=0.67e-3
.param c_den3=0.5e-3
.param c_sub=1
.param c_mpc=1
.lib 'ts18sl_scl_2019.lib' mfc
.endl mfc_typ

.lib mfc_high
.param c_den=1.04e-3
.param c_den6=1.25e-3
.param c_den4=0.83e-3
.param c_den3=0.62e-3
.param c_sub=0.85
.param c_mpc=1.2
.lib 'ts18sl_scl_2019.lib' mfc
.endl mfc_high

.lib mfc_low
.param c_den=0.64e-3
.param c_den6=0.77e-3
.param c_den4=0.51e-3
.param c_den3=0.38e-3
.param c_sub=1.15
.param c_mpc=0.8
.lib 'ts18sl_scl_2019.lib' mfc
.endl mfc_low


.lib mfc



.subckt usgcm52t n1 n2 l=length nf=num_fingers m=1
.param c_density='c_den*1.136'
.param pitch=0.58e-6	
.param ptc1=23.554e-6   
.param ptc2=0.0291e-6   
.param vc2=-5.5e-7   
.param pt='temper'  
.param Al='log(l*10)/abs(log(l*10))'
.param lreal='0.5*(l*(1+Al)*1e-6+l*(1-Al))'    
.param tfac='1.0+ptc1*(pt-25.0)+ptc2*(pt-25.0)*(pt-25.0)'
.param mfcmatch= 'sqrt(0.5)*(2.4e-6/(lreal*2*nf*2*m) + 6.6e-4)'
.param rfac= agauss(0,mfcmatch,1)
c1 n1 n2 '(2*nf-1)*c_density*lreal*pitch*tfac*(1-rfac)*(1+vc2*v(n1,n2)*v(n1,n2))'
.ends usgcm52t 


.subckt usgcm53t n1 n2 n3 l=length nf=num_fingers m=1
.param c_density='c_den*1.136'
.param pitch=0.58e-6	
.param ptc1=23.554e-6   
.param ptc2=0.0291e-6   
.param vc2=-5.5e-7   
.param c_density_parasitic='1.79e-5*c_sub'
.param pt='temper'  
.param Al='log(l*10)/abs(log(l*10))'
.param lreal='0.5*(l*(1+Al)*1e-6+l*(1-Al))'              	
.param tfac='1.0+ptc1*(pt-25.0)+ptc2*(pt-25.0)*(pt-25.0)'
.param mfcmatch= 'sqrt(0.5)*(2.4e-6/(lreal*2*nf*2*m) + 6.6e-4)'
.param rfac= agauss(0,mfcmatch,1)
c1 n1 n2 '(2*nf-1)*c_density*lreal*pitch*tfac*(1-rfac)*(1+vc2*v(n1,n2)*v(n1,n2))'
cp1 n1 n3 'nf*c_density_parasitic*lreal*pitch*tfac'
cp2 n2 n3 'nf*c_density_parasitic*lreal*pitch*tfac'
.ends usgcm53t 


.subckt usgcm32t n1 n2 l=length nf=num_fingers m=1
.param c_density='c_den3*1.136'
.param pitch=0.58e-6	
.param ptc1=23.554e-6   
.param ptc2=0.0291e-6   
.param vc2=-5.5e-7   
.param pt='temper'  
.param Al='log(l*10)/abs(log(l*10))'
.param lreal='0.5*(l*(1+Al)*1e-6+l*(1-Al))'    
.param tfac='1.0+ptc1*(pt-25.0)+ptc2*(pt-25.0)*(pt-25.0)'
.param mfcmatch= 'sqrt(0.5)*(2.4e-6/(lreal*2*nf*2*m) + 6.6e-4)'
.param rfac= agauss(0,mfcmatch,1)
c1 n1 n2 '(2*nf-1)*c_density*lreal*pitch*tfac*(1-rfac)*(1+vc2*v(n1,n2)*v(n1,n2))'
.ends usgcm32t 

.subckt usgcm33t n1 n2 n3 l=length nf=num_fingers m=1
.param c_density='c_den3*1.136'
.param pitch=0.58e-6	
.param ptc1=23.554e-6   
.param ptc2=0.0291e-6   
.param vc2=-5.5e-7   
.param c_density_parasitic='1.79e-5*c_sub'
.param pt='temper'  
.param Al='log(l*10)/abs(log(l*10))'
.param lreal='0.5*(l*(1+Al)*1e-6+l*(1-Al))'              	
.param tfac='1.0+ptc1*(pt-25.0)+ptc2*(pt-25.0)*(pt-25.0)'
.param mfcmatch= 'sqrt(0.5)*(2.4e-6/(lreal*2*nf*2*m) + 6.6e-4)'
.param rfac= agauss(0,mfcmatch,1)
c1 n1 n2 '(2*nf-1)*c_density*lreal*pitch*tfac*(1-rfac)*(1+vc2*v(n1,n2)*v(n1,n2))'
cp1 n1 n3 'nf*c_density_parasitic*lreal*pitch*tfac'
cp2 n2 n3 'nf*c_density_parasitic*lreal*pitch*tfac'
.ends usgcm33t


.endl mfc


*******************************
	*RESISTORS MODELS*
*******************************


.lib res2tnew_typ
.param
+dw_lytho_2t=0             dl_lytho_2t=0
+var_tch2t=1
+cres_mr23t_2t=7 rsh_mr23t_2t=2000 
.lib 'ts18sl_scl_2019.lib' res2tnew
.endl res2tnew_typ


.lib res2tnew_high
.param
+dw_lytho_2t=+0.022u        dl_lytho_2t=+0.015u
+var_tch2t=1.12
+cres_mr23t_2t=30 rsh_mr23t_2t=2320 
.lib 'ts18sl_scl_2019.lib' res2tnew
.endl res2tnew_high


.lib res2tnew_low
.param
+dw_lytho_2t=-0.022u        dl_lytho_2t=-0.015u
+var_tch2t=0.88
+cres_mr23t_2t=1 rsh_mr23t_2t=1700
.lib 'ts18sl_scl_2019.lib' res2tnew
.endl res2tnew_low


.lib res2tnew



.subckt mr22t n1 n2 l='1u' w='1u' ssegs=1 m=1
.param aw='log(w*10)/abs(log(w*10))'
.param al='log(l*10)/abs(log(l*10))'
.param wreal='0.5*(w*(1+aw)*1e-6+w*(1-aw))'
.param lreal='0.5*(l*(1+al)*1e-6+l*(1-al))'
.param ca='9.55320e-05'
.param cp='1.66935e-11'
.param cres='cres_mr23t_2t'
.param dw='20.0e-9+dw_lytho_2t'
.param pitch=0.47e-6
.param rint='-75.6e-6+dl_lytho_2t*2000'
.param rsh='rsh_mr23t_2t'
.param tc1='-1.688m*var_tch2t'
.param tc2=3.44u
.param vc1='-0.142m/ssegs'
.param vc2='-0.01645m/(ssegs*ssegs)'
.param pt='temper'
.param apelg=1.67e-8
.param rmatch = '(apelg/sqrt(2*lreal*wreal*m))'
.param rfac = agauss(0,rmatch,1)
.param r3fac = agauss(0,1,1)
.param match_r  = '1-rfac'
.param tfac = '(1+tc1*(pt-27)+tc2*(pt-27)*(pt-27))'
.param rcon = '(cres*pitch)/wreal'
.param rend = 'rint/(wreal-dw)'
r1 n1 n2 '2*rcon*ssegs + rsh*lreal/(wreal-dw)*(1+vc1*abs(v(n2,n1))+vc2*v(n2,n1)*v(n2,n1))*tfac*match_r'
.ends mr22t

.endl res2tnew


.lib res3tnew_typ
.param
+cres_mr23t_3t=7        rsh_mr23t_3t=2000 
+dw_lytho=0.0           dl_lytho=0.0
+var_tch=1
.lib 'ts18sl_scl_2019.lib' res3tnew
.endl res3tnew_typ


.lib res3tnew_high
.param
+cres_mr23t_3t=30       rsh_mr23t_3t=2320 
+dw_lytho=+0.022u       dl_lytho=+0.015u
+var_tch=1.12
.lib 'ts18sl_scl_2019.lib' res3tnew
.endl res3tnew_high


.lib res3tnew_low
.param
+cres_mr23t_3t=1        rsh_mr23t_3t=1700 
+dw_lytho=-0.022u       dl_lytho=-0.015u
+var_tch=0.88
.lib 'ts18sl_scl_2019.lib' res3tnew
.endl res3tnew_low

.lib res3tnew

*** .hdl 'r3_cmc.va' [REMOVED]




.subckt mr23t n1 n2 n3 l='1u' w='1u' ssegs=1 m=1
.param aw='log(w*10)/abs(log(w*10))'
.param al='log(l*10)/abs(log(l*10))'
.param wreal='0.5*(w*(1+aw)*1e-6+w*(1-aw))'
.param lreal='0.5*(l*(1+al)*1e-6+l*(1-al))'
.param ca='9.55320e-05'
.param cp='1.66935e-11'
.param cres='cres_mr23t_3t'
.param dw='20.0e-9+dw_lytho'
.param pitch=0.47e-6
.param rint='-75.6e-6+dl_lytho*2000'
.param rsh='rsh_mr23t_3t'
.param tc1='-1.688m*var_tch'
.param tc2=3.44u
.param vc1='-0.142m/ssegs'
.param vc2='-16.45u/(ssegs*ssegs)'
.param pt='temper'
.param apelg=1.67e-8
.param rmatch = '(apelg/sqrt(2*lreal*wreal*m))'
.param rfac = agauss(0,rmatch,1)
.param r3fac = agauss(0,1,1)
.param match_r  = '1-rfac'
.param tfac = '(1+tc1*(pt-27)+tc2*(pt-27)*(pt-27))'
.param rcon = '(cres*pitch)/wreal'
.param rend = 'rint/(wreal-dw)'
.param dl_r1='rint*ssegs*1e-3'
rc1 n1 a 'rcon*ssegs' 
r1 a b 'rsh*(lreal+dl_r1)/(4*(wreal-dw))*(1+vc1*abs(v(n2,n1))+vc2*v(n2,n1)*v(n2,n1))*tfac*match_r' 
r2 b c 'rsh*(lreal+dl_r1)/(4*(wreal-dw))*(1+vc1*abs(v(n2,n1))+vc2*v(n2,n1)*v(n2,n1))*tfac*match_r' 
r3 c d 'rsh*(lreal+dl_r1)/(4*(wreal-dw))*(1+vc1*abs(v(n2,n1))+vc2*v(n2,n1)*v(n2,n1))*tfac*match_r' 
r4 d e 'rsh*(lreal+dl_r1)/(4*(wreal-dw))*(1+vc1*abs(v(n2,n1))+vc2*v(n2,n1)*v(n2,n1))*tfac*match_r' 
rc2 e n2 'rcon*ssegs' 
c1 a n3 '(ca*(wreal-dw) + 2*cp)*(lreal/5)' 
c2 b n3 '(ca*(wreal-dw) + 2*cp)*(lreal/5)' 
c3 c n3 '(ca*(wreal-dw) + 2*cp)*(lreal/5)' 
c4 d n3 '(ca*(wreal-dw) + 2*cp)*(lreal/5)' 
c5 e n3 '(ca*(wreal-dw) + 2*cp)*(lreal/5)' 
.ends mr23t

.endl res3tnew


